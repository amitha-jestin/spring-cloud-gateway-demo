{
  "title": "Booking Service — Metrics & Logs",
  "uid": "booking-service-dashboard",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["booking-service"],
  "panels": [
    {
      "id": 1, "title": "Request Rate (req/sec)", "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "targets": [{ "datasource": "Prometheus",
        "expr": "sum(rate(http_server_requests_seconds_count{application=\"booking-service\"}[1m])) by (uri, method)",
        "legendFormat": "{{method}} {{uri}}" }]
    },
    {
      "id": 2, "title": "Error Rate (%)", "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "targets": [{ "datasource": "Prometheus",
        "expr": "sum(rate(http_server_requests_seconds_count{application=\"booking-service\",status=~\"4..|5..\"}[1m])) / sum(rate(http_server_requests_seconds_count{application=\"booking-service\"}[1m])) * 100",
        "legendFormat": "Error %" }]
    },
    {
      "id": 3, "title": "P95 / P99 Latency (ms)", "type": "timeseries",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
      "targets": [
        { "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"booking-service\"}[1m])) by (le)) * 1000",
          "legendFormat": "P95" },
        { "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=\"booking-service\"}[1m])) by (le)) * 1000",
          "legendFormat": "P99" }
      ]
    },
    {
      "id": 4, "title": "JVM Heap Usage", "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [{ "datasource": "Prometheus",
        "expr": "jvm_memory_used_bytes{application=\"booking-service\", area=\"heap\"}",
        "legendFormat": "Heap — {{id}}" }]
    },
    {
      "id": 5, "title": "Active Threads", "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [{ "datasource": "Prometheus",
        "expr": "jvm_threads_live_threads{application=\"booking-service\"}",
        "legendFormat": "Live Threads" }]
    },
    {
      "id": 6, "title": "Booking Service Logs", "type": "logs",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 10 },
      "targets": [{ "datasource": "Loki", "expr": "{app=\"booking-service\"} | json" }]
    }
  ]
}
